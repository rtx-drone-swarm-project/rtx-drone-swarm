# Copy this file to .env and adjust paths/ports for your machine.

# Absolute path to your local ArduPilot checkout on the host.
ARDUPILOT_PATH=/Users/your-user/ardupilot

# SITL swarm settings.
SITL_COUNT=15
SITL_HOST=sitl
SITL_BASE_PORT=5760
SITL_PORT_STEP=10

# Local app ports.
BACKEND_PORT=8000
FRONTEND_PORT=5173
